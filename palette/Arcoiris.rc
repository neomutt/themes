# Arcoiris – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Arcoiris
#
# Base palette
# bg:  #201f1e
# fg:  #eee4d9
# grey:#777777

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color254 color234
color error color160 color234
color message color69 color234
color indicator color234 color223
color tree color243 color234

########################################
# Status Bar
########################################

color status color254 color243

########################################
# Index View
########################################

color index color254 color234
color index_number color243 color234
color index_author color69 color234
color index_subject color254 color234
color index_date color221 color234
color index_flags color217 color234

color index color160 color234 "~D"
color index color223 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color254 color234
color header color69 color234 "^From:"
color header color69 color234 "^To:"
color header color221 color234 "^Subject:"
color header color221 color234 "^Date:"
color header color158 color234 "^Reply-To:"
color header color158 color234 "^Message-ID:"

########################################
# Body
########################################

color body color254 color234 ".*"
color quoted0 color193 color234
color quoted1 color158 color234
color signature color243 color234
color body color153 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color221

########################################
# Compose
########################################

color compose_header color69 color234
color compose_security_encrypt color217 color234
color compose_security_sign color193 color234
color compose_security_both color158 color234

########################################
# Diff / Patch
########################################

color body color234 color193 "^\\+.*"
color body color234 color160 "^-.*"
color body color234 color221 "^@@.*"

# vim: ft=neomuttrc
