# IC Orange PPL – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: IC Orange PPL
#
# Base palette
# bg:  #262626
# fg:  #ffcb83
# grey:#6a4f2a

########################################
# Global Defaults
########################################

color normal color222 color235
color error color130 color235
color message color130 color235
color indicator color235 color221
color tree color239 color235

########################################
# Status Bar
########################################

color status color222 color239

########################################
# Index View
########################################

color index color222 color235
color index_number color239 color235
color index_author color130 color235
color index_subject color222 color235
color index_date color178 color235
color index_flags color209 color235

color index color130 color235 "~D"
color index color221 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color222 color235
color header color130 color235 "^From:"
color header color130 color235 "^To:"
color header color178 color235 "^Subject:"
color header color178 color235 "^Date:"
color header color173 color235 "^Reply-To:"
color header color173 color235 "^Message-ID:"

########################################
# Body
########################################

color body color222 color235 ".*"
color quoted0 color227 color235
color quoted1 color173 color235
color signature color239 color235
color body color215 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color178

########################################
# Compose
########################################

color compose_header color130 color235
color compose_security_encrypt color209 color235
color compose_security_sign color227 color235
color compose_security_both color173 color235

########################################
# Diff / Patch
########################################

color body color235 color227 "^\\+.*"
color body color235 color130 "^-.*"
color body color235 color178 "^@@.*"

