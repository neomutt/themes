# Abernathy – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Abernathy
#
# Base palette
# bg:  #111416
# fg:  #eeeeec
# grey:#404040

########################################
# Global Defaults
########################################

color normal color255 color233
color error color160 color233
color message color33 color233
color indicator color233 color11
color tree color238 color233

########################################
# Status Bar
########################################

color status color255 color238

########################################
# Index View
########################################

color index color255 color233
color index_number color238 color233
color index_author color33 color233
color index_subject color255 color233
color index_date color184 color233
color index_flags color9 color233

color index color160 color233 "~D"
color index color11 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color255 color233
color header color33 color233 "^From:"
color header color33 color233 "^To:"
color header color184 color233 "^Subject:"
color header color184 color233 "^Date:"
color header color14 color233 "^Reply-To:"
color header color14 color233 "^Message-ID:"

########################################
# Body
########################################

color body color255 color233 ".*"
color quoted0 color10 color233
color quoted1 color14 color233
color signature color238 color233
color body color39 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color184

########################################
# Compose
########################################

color compose_header color33 color233
color compose_security_encrypt color9 color233
color compose_security_sign color10 color233
color compose_security_both color14 color233

########################################
# Diff / Patch
########################################

color body color233 color10 "^\\+.*"
color body color233 color160 "^-.*"
color body color233 color184 "^@@.*"

# vim: ft=neomuttrc
