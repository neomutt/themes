# Nord Wave – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Nord Wave
#
# Base palette
# bg:  #212121
# fg:  #d8dee9
# grey:#4c566a

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color254 color234
color error color131 color234
color message color109 color234
color indicator color234 color186
color tree color240 color234

########################################
# Status Bar
########################################

color status color254 color240

########################################
# Index View
########################################

color index color254 color234
color index_number color240 color234
color index_author color109 color234
color index_subject color254 color234
color index_date color186 color234
color index_flags color131 color234

color index color131 color234 "~D"
color index color186 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color254 color234
color header color109 color234 "^From:"
color header color109 color234 "^To:"
color header color186 color234 "^Subject:"
color header color186 color234 "^Date:"
color header color109 color234 "^Reply-To:"
color header color109 color234 "^Message-ID:"

########################################
# Body
########################################

color body color254 color234 ".*"
color quoted0 color144 color234
color quoted1 color109 color234
color signature color240 color234
color body color109 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color186

########################################
# Compose
########################################

color compose_header color109 color234
color compose_security_encrypt color131 color234
color compose_security_sign color144 color234
color compose_security_both color109 color234

########################################
# Diff / Patch
########################################

color body color234 color144 "^\\+.*"
color body color234 color131 "^-.*"
color body color234 color186 "^@@.*"

# vim: ft=neomuttrc
