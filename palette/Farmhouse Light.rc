########################################
# Body
########################################

color body color235 color254 ".*"
color quoted0 color106 color254
color quoted1 color41 color254
color signature color238 color254
color body color27 color254 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color254 color130

########################################
