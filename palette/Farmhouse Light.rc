########################################
# Global Defaults
########################################

color normal color235 color254
color error color88 color254
color message color20 color254
color indicator color254 color172
color tree color238 color254

########################################
# Status Bar
########################################

color status color235 color238

########################################
# Index View
########################################

color index color235 color254
color index_number color238 color254
color index_author color20 color254
color index_subject color235 color254
color index_date color130 color254
color index_flags color9 color254

color index color88 color254 "~D"
