# Belafonte Night – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Belafonte Night
#
# Base palette
# bg:  #20111b
# fg:  #968c83
# grey:#5e5252

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color245 color234
color error color124 color234
color message color60 color234
color indicator color234 color179
color tree color240 color234

########################################
# Status Bar
########################################

color status color245 color240

########################################
# Index View
########################################

color index color245 color234
color index_number color240 color234
color index_author color60 color234
color index_subject color245 color234
color index_date color179 color234
color index_flags color124 color234

color index color124 color234 "~D"
color index color179 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color245 color234
color header color60 color234 "^From:"
color header color60 color234 "^To:"
color header color179 color234 "^Subject:"
color header color179 color234 "^Date:"
color header color247 color234 "^Reply-To:"
color header color247 color234 "^Message-ID:"

########################################
# Body
########################################

color body color245 color234 ".*"
color quoted0 color101 color234
color quoted1 color247 color234
color signature color240 color234
color body color60 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color179

########################################
# Compose
########################################

color compose_header color60 color234
color compose_security_encrypt color124 color234
color compose_security_sign color101 color234
color compose_security_both color247 color234

########################################
# Diff / Patch
########################################

color body color234 color101 "^\\+.*"
color body color234 color124 "^-.*"
color body color234 color179 "^@@.*"

# vim: ft=neomuttrc
