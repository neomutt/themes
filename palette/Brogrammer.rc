# Brogrammer – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Brogrammer
#
# Base palette
# bg:  #131313
# fg:  #d6dbe5
# grey:#d6dbe5

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color253 color233
color error color9 color233
color message color32 color233
color indicator color233 color214
color tree color253 color233

########################################
# Status Bar
########################################

color status color253 color253

########################################
# Index View
########################################

color index color253 color233
color index_number color253 color233
color index_author color32 color233
color index_subject color253 color233
color index_date color214 color233
color index_flags color166 color233

color index color9 color233 "~D"
color index color214 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color253 color233
color header color32 color233 "^From:"
color header color32 color233 "^To:"
color header color214 color233 "^Subject:"
color header color214 color233 "^Date:"
color header color32 color233 "^Reply-To:"
color header color32 color233 "^Message-ID:"

########################################
# Body
########################################

color body color253 color233 ".*"
color quoted0 color41 color233
color quoted1 color32 color233
color signature color253 color233
color body color32 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color214

########################################
# Compose
########################################

color compose_header color32 color233
color compose_security_encrypt color166 color233
color compose_security_sign color41 color233
color compose_security_both color32 color233

########################################
# Diff / Patch
########################################

color body color233 color41 "^\\+.*"
color body color233 color9 "^-.*"
color body color233 color214 "^@@.*"

# vim: ft=neomuttrc
