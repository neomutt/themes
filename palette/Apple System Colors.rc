# Apple System Colors – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Apple System Colors
#
# Base palette
# bg:  #1e1e1e
# fg:  #ffffff
# grey:#464646

########################################
# Global Defaults
########################################

color normal color15 color234
color error color166 color234
color message color26 color234
color indicator color234 color220
color tree color238 color234

########################################
# Status Bar
########################################

color status color15 color238

########################################
# Index View
########################################

color index color15 color234
color index_number color238 color234
color index_author color26 color234
color index_subject color15 color234
color index_date color178 color234
color index_flags color203 color234

color index color166 color234 "~D"
color index color220 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color15 color234
color header color26 color234 "^From:"
color header color26 color234 "^To:"
color header color178 color234 "^Subject:"
color header color178 color234 "^Date:"
color header color117 color234 "^Reply-To:"
color header color117 color234 "^Message-ID:"

########################################
# Body
########################################

color body color15 color234 ".*"
color quoted0 color77 color234
color quoted1 color117 color234
color signature color238 color234
color body color33 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color178

########################################
# Compose
########################################

color compose_header color26 color234
color compose_security_encrypt color203 color234
color compose_security_sign color77 color234
color compose_security_both color117 color234

########################################
# Diff / Patch
########################################

color body color234 color77 "^\\+.*"
color body color234 color166 "^-.*"
color body color234 color178 "^@@.*"

# vim: ft=neomuttrc
