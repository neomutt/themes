# Modus Operandi – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Modus Operandi
#
# Base palette
# bg:  #ffffff
# fg:  #000000
# grey:#595959

########################################
# Global Defaults
########################################

color normal color0 color15
color error color124 color15
color message color25 color15
color indicator color15 color94
color tree color240 color15

########################################
# Status Bar
########################################

color status color0 color240

########################################
# Index View
########################################

color index color0 color15
color index_number color240 color15
color index_author color25 color15
color index_subject color0 color15
color index_date color58 color15
color index_flags color88 color15

color index color124 color15 "~D"
color index color94 color15 "~T"

########################################
# Headers
########################################

color hdrdefault color0 color15
color header color25 color15 "^From:"
color header color25 color15 "^To:"
color header color58 color15 "^Subject:"
color header color58 color15 "^Date:"
color header color23 color15 "^Reply-To:"
color header color23 color15 "^Message-ID:"

########################################
# Body
########################################

color body color0 color15 ".*"
color quoted0 color23 color15
color quoted1 color23 color15
color signature color240 color15
color body color62 color15 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color15 color58

########################################
# Compose
########################################

color compose_header color25 color15
color compose_security_encrypt color88 color15
color compose_security_sign color23 color15
color compose_security_both color23 color15

########################################
# Diff / Patch
########################################

color body color15 color23 "^\\+.*"
color body color15 color124 "^-.*"
color body color15 color58 "^@@.*"

# vim: ft=neomuttrc
