# Molokai – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Molokai
#
# Base palette
# bg:  #121212
# fg:  #bbbbbb
# grey:#555555

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color250 color233
color error color197 color233
color message color32 color233
color indicator color233 color227
color tree color240 color233

########################################
# Status Bar
########################################

color status color250 color240

########################################
# Index View
########################################

color index color250 color233
color index_number color240 color233
color index_author color32 color233
color index_subject color250 color233
color index_date color185 color233
color index_flags color205 color233

color index color197 color233 "~D"
color index color227 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color250 color233
color header color32 color233 "^From:"
color header color32 color233 "^To:"
color header color185 color233 "^Subject:"
color header color185 color233 "^Date:"
color header color81 color233 "^Reply-To:"
color header color81 color233 "^Message-ID:"

########################################
# Body
########################################

color body color250 color233 ".*"
color quoted0 color149 color233
color quoted1 color81 color233
color signature color240 color233
color body color39 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color185

########################################
# Compose
########################################

color compose_header color32 color233
color compose_security_encrypt color205 color233
color compose_security_sign color149 color233
color compose_security_both color81 color233

########################################
# Diff / Patch
########################################

color body color233 color149 "^\\+.*"
color body color233 color197 "^-.*"
color body color233 color185 "^@@.*"

# vim: ft=neomuttrc
