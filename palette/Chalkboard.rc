########################################

color normal color254 color235
color error color131 color235
color message color61 color235
color indicator color235 color187
color tree color240 color235

########################################
# Status Bar
########################################

color status color254 color240

########################################
# Index View
########################################

color index color254 color235
color index_number color240 color235
color index_author color61 color235
color index_subject color254 color235
color index_date color143 color235
color index_flags color181 color235

color index color131 color235 "~D"
