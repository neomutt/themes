########################################
# Body
########################################

color body color254 color235 ".*"
color quoted0 color151 color235
color quoted1 color152 color235
color signature color240 color235
color body color146 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color143

########################################
