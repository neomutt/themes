# No Clown Fiesta Light – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: No Clown Fiesta Light
#
# Base palette
# bg:  #e1e1e1
# fg:  #151515
# grey:#2b2b2b

########################################
# Global Defaults
########################################

color normal color233 color254
color error color95 color254
color message color109 color254
color indicator color254 color137
color tree color235 color254

########################################
# Status Bar
########################################

color status color233 color235

########################################
# Index View
########################################

color index color233 color254
color index_number color235 color254
color index_author color109 color254
color index_subject color233 color254
color index_date color137 color254
color index_flags color66 color254

color index color95 color254 "~D"
color index color137 color254 "~T"

########################################
# Headers
########################################

color hdrdefault color233 color254
color header color109 color254 "^From:"
color header color109 color254 "^To:"
color header color137 color254 "^Subject:"
color header color137 color254 "^Date:"
color header color247 color254 "^Reply-To:"
color header color247 color254 "^Message-ID:"

########################################
# Body
########################################

color body color233 color254 ".*"
color quoted0 color65 color254
color quoted1 color247 color254
color signature color235 color254
color body color247 color254 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color254 color137

########################################
# Compose
########################################

color compose_header color109 color254
color compose_security_encrypt color66 color254
color compose_security_sign color65 color254
color compose_security_both color247 color254

########################################
# Diff / Patch
########################################

color body color254 color65 "^\\+.*"
color body color254 color95 "^-.*"
color body color254 color137 "^@@.*"

# vim: ft=neomuttrc
