# GitHub Light Colorblind – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: GitHub Light Colorblind
#
# Base palette
# bg:  #ffffff
# fg:  #24292f
# grey:#57606a

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color235 color15
color error color130 color15
color message color26 color15
color indicator color15 color58
color tree color59 color15

########################################
# Status Bar
########################################

color status color235 color59

########################################
# Index View
########################################

color index color235 color15
color index_number color59 color15
color index_author color26 color15
color index_subject color235 color15
color index_date color52 color15
color index_flags color94 color15

color index color130 color15 "~D"
color index color58 color15 "~T"

########################################
# Headers
########################################

color hdrdefault color235 color15
color header color26 color15 "^From:"
color header color26 color15 "^To:"
color header color52 color15 "^Subject:"
color header color52 color15 "^Date:"
color header color67 color15 "^Reply-To:"
color header color67 color15 "^Message-ID:"

########################################
# Body
########################################

color body color235 color15 ".*"
color quoted0 color26 color15
color quoted1 color67 color15
color signature color59 color15
color body color33 color15 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color15 color52

########################################
# Compose
########################################

color compose_header color26 color15
color compose_security_encrypt color94 color15
color compose_security_sign color26 color15
color compose_security_both color67 color15

########################################
# Diff / Patch
########################################

color body color15 color26 "^\\+.*"
color body color15 color130 "^-.*"
color body color15 color52 "^@@.*"

# vim: ft=neomuttrc
