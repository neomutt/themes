# Elegant – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Elegant
#
# Base palette
# bg:  #292b31
# fg:  #ced2d6
# grey:#575656

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color252 color236
color error color197 color236
color message color110 color236
color indicator color236 color222
color tree color240 color236

########################################
# Status Bar
########################################

color status color252 color240

########################################
# Index View
########################################

color index color252 color236
color index_number color240 color236
color index_author color110 color236
color index_subject color252 color236
color index_date color222 color236
color index_flags color197 color236

color index color197 color236 "~D"
color index color222 color236 "~T"

########################################
# Headers
########################################

color hdrdefault color252 color236
color header color110 color236 "^From:"
color header color110 color236 "^To:"
color header color222 color236 "^Subject:"
color header color222 color236 "^Date:"
color header color75 color236 "^Reply-To:"
color header color75 color236 "^Message-ID:"

########################################
# Body
########################################

color body color252 color236 ".*"
color quoted0 color114 color236
color quoted1 color75 color236
color signature color240 color236
color body color110 color236 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color236 color222

########################################
# Compose
########################################

color compose_header color110 color236
color compose_security_encrypt color197 color236
color compose_security_sign color114 color236
color compose_security_both color75 color236

########################################
# Diff / Patch
########################################

color body color236 color114 "^\\+.*"
color body color236 color197 "^-.*"
color body color236 color222 "^@@.*"

# vim: ft=neomuttrc
