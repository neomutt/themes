# branch – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: branch
#
# Base palette
# bg:  #32221a
# fg:  #cfc1a9
# grey:#564a45

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color181 color235
color error color130 color235
color message color66 color235
color indicator color235 color173
color tree color239 color235

########################################
# Status Bar
########################################

color status color181 color239

########################################
# Index View
########################################

color index color181 color235
color index_number color239 color235
color index_author color66 color235
color index_subject color181 color235
color index_date color173 color235
color index_flags color130 color235

color index color130 color235 "~D"
color index color173 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color181 color235
color header color66 color235 "^From:"
color header color66 color235 "^To:"
color header color173 color235 "^Subject:"
color header color173 color235 "^Date:"
color header color66 color235 "^Reply-To:"
color header color66 color235 "^Message-ID:"

########################################
# Body
########################################

color body color181 color235 ".*"
color quoted0 color107 color235
color quoted1 color66 color235
color signature color239 color235
color body color66 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color173

########################################
# Compose
########################################

color compose_header color66 color235
color compose_security_encrypt color130 color235
color compose_security_sign color107 color235
color compose_security_both color66 color235

########################################
# Diff / Patch
########################################

color body color235 color107 "^\\+.*"
color body color235 color130 "^-.*"
color body color235 color173 "^@@.*"

# vim: ft=neomuttrc
