########################################
# Global Defaults
########################################

color normal color251 color235
color error color210 color235
color message color81 color235
color indicator color235 color221
color tree color242 color235

########################################
# Status Bar
########################################

color status color251 color242

########################################
# Index View
########################################

color index color251 color235
color index_number color242 color235
color index_author color81 color235
color index_subject color251 color235
color index_date color221 color235
color index_flags color210 color235

color index color210 color235 "~D"
color index color221 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color251 color235
color header color81 color235 "^From:"
color header color81 color235 "^To:"
color header color221 color235 "^Subject:"
color header color221 color235 "^Date:"
color header color116 color235 "^Reply-To:"
color header color116 color235 "^Message-ID:"

########################################
# Body
########################################

color body color251 color235 ".*"
color quoted0 color192 color235
color quoted1 color116 color235
color signature color242 color235
color body color81 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color221

########################################
# Compose
########################################

color compose_header color81 color235
color compose_security_encrypt color210 color235
color compose_security_sign color192 color235
