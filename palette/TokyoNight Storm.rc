# TokyoNight Storm – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: TokyoNight Storm
#
# Base palette
# bg:  #24283b
# fg:  #c0caf5
# grey:#4e5575

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color153 color236
color error color210 color236
color message color111 color236
color indicator color236 color179
color tree color60 color236

########################################
# Status Bar
########################################

color status color153 color60

########################################
# Index View
########################################

color index color153 color236
color index_number color60 color236
color index_author color111 color236
color index_subject color153 color236
color index_date color179 color236
color index_flags color210 color236

color index color210 color236 "~D"
color index color179 color236 "~T"

########################################
# Headers
########################################

color hdrdefault color153 color236
color header color111 color236 "^From:"
color header color111 color236 "^To:"
color header color179 color236 "^Subject:"
color header color179 color236 "^Date:"
color header color117 color236 "^Reply-To:"
color header color117 color236 "^Message-ID:"

########################################
# Body
########################################

color body color153 color236 ".*"
color quoted0 color149 color236
color quoted1 color117 color236
color signature color60 color236
color body color111 color236 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color236 color179

########################################
# Compose
########################################

color compose_header color111 color236
color compose_security_encrypt color210 color236
color compose_security_sign color149 color236
color compose_security_both color117 color236

########################################
# Diff / Patch
########################################

color body color236 color149 "^\\+.*"
color body color236 color210 "^-.*"
color body color236 color179 "^@@.*"

# vim: ft=neomuttrc
