# Monokai Classic – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Monokai Classic
#
# Base palette
# bg:  #272822
# fg:  #fdfff1
# grey:#6e7066

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color15 color235
color error color197 color235
color message color208 color235
color indicator color235 color186
color tree color242 color235

########################################
# Status Bar
########################################

color status color15 color242

########################################
# Index View
########################################

color index color15 color235
color index_number color242 color235
color index_author color208 color235
color index_subject color15 color235
color index_date color186 color235
color index_flags color197 color235

color index color197 color235 "~D"
color index color186 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color15 color235
color header color208 color235 "^From:"
color header color208 color235 "^To:"
color header color186 color235 "^Subject:"
color header color186 color235 "^Date:"
color header color81 color235 "^Reply-To:"
color header color81 color235 "^Message-ID:"

########################################
# Body
########################################

color body color15 color235 ".*"
color quoted0 color148 color235
color quoted1 color81 color235
color signature color242 color235
color body color208 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color186

########################################
# Compose
########################################

color compose_header color208 color235
color compose_security_encrypt color197 color235
color compose_security_sign color148 color235
color compose_security_both color81 color235

########################################
# Diff / Patch
########################################

color body color235 color148 "^\\+.*"
color body color235 color197 "^-.*"
color body color235 color186 "^@@.*"

# vim: ft=neomuttrc
