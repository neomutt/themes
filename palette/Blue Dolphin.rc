# Blue Dolphin – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Blue Dolphin
#
# Base palette
# bg:  #006984
# fg:  #c5f2ff
# grey:#9094a4

########################################
# Global Defaults
########################################

color normal color195 color24
color error color210 color24
color message color111 color24
color indicator color24 color222
color tree color246 color24

########################################
# Status Bar
########################################

color status color195 color246

########################################
# Index View
########################################

color index color195 color24
color index_number color246 color24
color index_author color111 color24
color index_subject color195 color24
color index_date color223 color24
color index_flags color210 color24

color index color210 color24 "~D"
color index color222 color24 "~T"

########################################
# Headers
########################################

color hdrdefault color195 color24
color header color111 color24 "^From:"
color header color111 color24 "^To:"
color header color223 color24 "^Subject:"
color header color223 color24 "^Date:"
color header color159 color24 "^Reply-To:"
color header color159 color24 "^Message-ID:"

########################################
# Body
########################################

color body color195 color24 ".*"
color quoted0 color193 color24
color quoted1 color159 color24
color signature color246 color24
color body color153 color24 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color24 color223

########################################
# Compose
########################################

color compose_header color111 color24
color compose_security_encrypt color210 color24
color compose_security_sign color193 color24
color compose_security_both color159 color24

########################################
# Diff / Patch
########################################

color body color24 color193 "^\\+.*"
color body color24 color210 "^-.*"
color body color24 color223 "^@@.*"

