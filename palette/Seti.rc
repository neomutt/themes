# Seti – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Seti
#
# Base palette
# bg:  #111213
# fg:  #cacecd
# grey:#3f3f3f

########################################
# Global Defaults
########################################

color normal color252 color233
color error color125 color233
color message color74 color233
color indicator color233 color185
color tree color237 color233

########################################
# Status Bar
########################################

color status color252 color237

########################################
# Index View
########################################

color index color252 color233
color index_number color237 color233
color index_author color74 color233
color index_subject color252 color233
color index_date color185 color233
color index_flags color125 color233

color index color125 color233 "~D"
color index color185 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color252 color233
color header color74 color233 "^From:"
color header color74 color233 "^To:"
color header color185 color233 "^Subject:"
color header color185 color233 "^Date:"
color header color113 color233 "^Reply-To:"
color header color113 color233 "^Message-ID:"

########################################
# Body
########################################

color body color252 color233 ".*"
color quoted0 color113 color233
color quoted1 color113 color233
color signature color237 color233
color body color74 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color185

########################################
# Compose
########################################

color compose_header color74 color233
color compose_security_encrypt color125 color233
color compose_security_sign color113 color233
color compose_security_both color113 color233

########################################
# Diff / Patch
########################################

color body color233 color113 "^\\+.*"
color body color233 color125 "^-.*"
color body color233 color185 "^@@.*"

# vim: ft=neomuttrc
