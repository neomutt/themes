# Dracula – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Dracula
#
# Base palette
# bg:  #282a36
# fg:  #f8f8f2
# grey:#6272a4

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color255 color236
color error color203 color236
color message color141 color236
color indicator color236 color229
color tree color61 color236

########################################
# Status Bar
########################################

color status color255 color61

########################################
# Index View
########################################

color index color255 color236
color index_number color61 color236
color index_author color141 color236
color index_subject color255 color236
color index_date color228 color236
color index_flags color203 color236

color index color203 color236 "~D"
color index color229 color236 "~T"

########################################
# Headers
########################################

color hdrdefault color255 color236
color header color141 color236 "^From:"
color header color141 color236 "^To:"
color header color228 color236 "^Subject:"
color header color228 color236 "^Date:"
color header color159 color236 "^Reply-To:"
color header color159 color236 "^Message-ID:"

########################################
# Body
########################################

color body color255 color236 ".*"
color quoted0 color84 color236
color quoted1 color159 color236
color signature color61 color236
color body color183 color236 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color236 color228

########################################
# Compose
########################################

color compose_header color141 color236
color compose_security_encrypt color203 color236
color compose_security_sign color84 color236
color compose_security_both color159 color236

########################################
# Diff / Patch
########################################

color body color236 color84 "^\\+.*"
color body color236 color203 "^-.*"
color body color236 color228 "^@@.*"

# vim: ft=neomuttrc
