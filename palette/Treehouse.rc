########################################
# Headers
########################################

color hdrdefault color95 color234
color header color66 color234 "^From:"
color header color66 color234 "^To:"
color header color136 color234 "^Subject:"
color header color136 color234 "^Date:"
color header color208 color234 "^Reply-To:"
