########################################
# Global Defaults
########################################

color normal color95 color234
color error color124 color234
color message color66 color234
color indicator color234 color215
color tree color238 color234

########################################
# Status Bar
########################################

color status color95 color238

########################################
# Index View
########################################

color index color95 color234
color index_number color238 color234
color index_author color66 color234
color index_subject color95 color234
color index_date color136 color234
color index_flags color202 color234

color index color124 color234 "~D"
