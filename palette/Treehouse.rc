########################################
# Body
########################################

color body color95 color234 ".*"
color quoted0 color83 color234
color quoted1 color208 color234
color signature color238 color234
color body color117 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color136

########################################
# Compose
########################################

