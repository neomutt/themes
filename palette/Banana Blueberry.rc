########################################
# Body
########################################

color body color252 color234 ".*"
color quoted0 color108 color234
color quoted1 color159 color234
color signature color240 color234
color body color123 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color184

########################################
# Compose
########################################

