########################################
# Global Defaults
########################################

color normal color252 color234
color error color204 color234
color message color44 color234
color indicator color234 color221
color tree color240 color234

########################################
# Status Bar
########################################

color status color252 color240

########################################
# Index View
########################################

color index color252 color234
color index_number color240 color234
color index_author color44 color234
color index_subject color252 color234
color index_date color184 color234
color index_flags color217 color234

color index color204 color234 "~D"
color index color221 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color252 color234
color header color44 color234 "^From:"
color header color44 color234 "^To:"
color header color184 color234 "^Subject:"
color header color184 color234 "^Date:"
color header color159 color234 "^Reply-To:"
