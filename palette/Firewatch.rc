# Firewatch – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Firewatch
#
# Base palette
# bg:  #1e2027
# fg:  #9ba2b2
# grey:#585f6d

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color248 color235
color error color167 color235
color message color68 color235
color indicator color235 color179
color tree color241 color235

########################################
# Status Bar
########################################

color status color248 color241

########################################
# Index View
########################################

color index color248 color235
color index_number color241 color235
color index_author color68 color235
color index_subject color248 color235
color index_date color179 color235
color index_flags color167 color235

color index color167 color235 "~D"
color index color179 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color248 color235
color header color68 color235 "^From:"
color header color68 color235 "^To:"
color header color179 color235 "^Subject:"
color header color179 color235 "^Date:"
color header color73 color235 "^Reply-To:"
color header color73 color235 "^Message-ID:"

########################################
# Body
########################################

color body color248 color235 ".*"
color quoted0 color72 color235
color quoted1 color73 color235
color signature color241 color235
color body color68 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color179

########################################
# Compose
########################################

color compose_header color68 color235
color compose_security_encrypt color167 color235
color compose_security_sign color72 color235
color compose_security_both color73 color235

########################################
# Diff / Patch
########################################

color body color235 color72 "^\\+.*"
color body color235 color167 "^-.*"
color body color235 color179 "^@@.*"

# vim: ft=neomuttrc
