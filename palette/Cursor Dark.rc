# Cursor Dark – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Cursor Dark
#
# Base palette
# bg:  #141414
# fg:  #ffffff
# grey:#505050

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color15 color233
color error color131 color233
color message color109 color233
color indicator color233 color186
color tree color239 color233

########################################
# Status Bar
########################################

color status color15 color239

########################################
# Index View
########################################

color index color15 color233
color index_number color239 color233
color index_author color109 color233
color index_subject color15 color233
color index_date color186 color233
color index_flags color131 color233

color index color131 color233 "~D"
color index color186 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color15 color233
color header color109 color233 "^From:"
color header color109 color233 "^To:"
color header color186 color233 "^Subject:"
color header color186 color233 "^Date:"
color header color110 color233 "^Reply-To:"
color header color110 color233 "^Message-ID:"

########################################
# Body
########################################

color body color15 color233 ".*"
color quoted0 color144 color233
color quoted1 color110 color233
color signature color239 color233
color body color109 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color186

########################################
# Compose
########################################

color compose_header color109 color233
color compose_security_encrypt color131 color233
color compose_security_sign color144 color233
color compose_security_both color110 color233

########################################
# Diff / Patch
########################################

color body color233 color144 "^\\+.*"
color body color233 color131 "^-.*"
color body color233 color186 "^@@.*"

# vim: ft=neomuttrc
