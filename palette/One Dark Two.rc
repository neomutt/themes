# One Dark Two – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: One Dark Two
#
# Base palette
# bg:  #21252b
# fg:  #e6e6e6
# grey:#4a505a

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color254 color235
color error color174 color235
color message color75 color235
color indicator color235 color222
color tree color239 color235

########################################
# Status Bar
########################################

color status color254 color239

########################################
# Index View
########################################

color index color254 color235
color index_number color239 color235
color index_author color75 color235
color index_subject color254 color235
color index_date color186 color235
color index_flags color174 color235

color index color174 color235 "~D"
color index color222 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color254 color235
color header color75 color235 "^From:"
color header color75 color235 "^To:"
color header color186 color235 "^Subject:"
color header color186 color235 "^Date:"
color header color116 color235 "^Reply-To:"
color header color116 color235 "^Message-ID:"

########################################
# Body
########################################

color body color254 color235 ".*"
color quoted0 color150 color235
color quoted1 color116 color235
color signature color239 color235
color body color117 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color186

########################################
# Compose
########################################

color compose_header color75 color235
color compose_security_encrypt color174 color235
color compose_security_sign color150 color235
color compose_security_both color116 color235

########################################
# Diff / Patch
########################################

color body color235 color150 "^\\+.*"
color body color235 color174 "^-.*"
color body color235 color186 "^@@.*"

# vim: ft=neomuttrc
