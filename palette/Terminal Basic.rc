# Terminal Basic – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Terminal Basic
#
# Base palette
# bg:  #ffffff
# fg:  #000000
# grey:#666666

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color0 color15
color error color88 color15
color message color19 color15
color indicator color15 color142
color tree color241 color15

########################################
# Status Bar
########################################

color status color0 color241

########################################
# Index View
########################################

color index color0 color15
color index_number color241 color15
color index_author color19 color15
color index_subject color0 color15
color index_date color100 color15
color index_flags color160 color15

color index color88 color15 "~D"
color index color142 color15 "~T"

########################################
# Headers
########################################

color hdrdefault color0 color15
color header color19 color15 "^From:"
color header color19 color15 "^To:"
color header color100 color15 "^Subject:"
color header color100 color15 "^Date:"
color header color44 color15 "^Reply-To:"
color header color44 color15 "^Message-ID:"

########################################
# Body
########################################

color body color0 color15 ".*"
color quoted0 color40 color15
color quoted1 color44 color15
color signature color241 color15
color body color12 color15 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color15 color100

########################################
# Compose
########################################

color compose_header color19 color15
color compose_security_encrypt color160 color15
color compose_security_sign color40 color15
color compose_security_both color44 color15

########################################
# Diff / Patch
########################################

color body color15 color40 "^\\+.*"
color body color15 color88 "^-.*"
color body color15 color100 "^@@.*"

# vim: ft=neomuttrc
