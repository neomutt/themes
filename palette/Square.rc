# Square – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Square
#
# Base palette
# bg:  #1a1a1a
# fg:  #acacab
# grey:#474747

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color145 color234
color error color174 color234
color message color152 color234
color indicator color234 color230
color tree color238 color234

########################################
# Status Bar
########################################

color status color145 color238

########################################
# Index View
########################################

color index color145 color234
color index_number color238 color234
color index_author color152 color234
color index_subject color145 color234
color index_date color223 color234
color index_flags color210 color234

color index color174 color234 "~D"
color index color230 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color145 color234
color header color152 color234 "^From:"
color header color152 color234 "^To:"
color header color223 color234 "^Subject:"
color header color223 color234 "^Date:"
color header color189 color234 "^Reply-To:"
color header color189 color234 "^Message-ID:"

########################################
# Body
########################################

color body color145 color234 ".*"
color quoted0 color156 color234
color quoted1 color189 color234
color signature color238 color234
color body color153 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color223

########################################
# Compose
########################################

color compose_header color152 color234
color compose_security_encrypt color210 color234
color compose_security_sign color156 color234
color compose_security_both color189 color234

########################################
# Diff / Patch
########################################

color body color234 color156 "^\\+.*"
color body color234 color174 "^-.*"
color body color234 color223 "^@@.*"

# vim: ft=neomuttrc
