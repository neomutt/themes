# Kanagawa Wave – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Kanagawa Wave
#
# Base palette
# bg:  #1f1f28
# fg:  #dcd7ba
# grey:#727169

########################################
# Global Defaults
########################################

color normal color187 color235
color error color131 color235
color message color110 color235
color indicator color235 color180
color tree color242 color235

########################################
# Status Bar
########################################

color status color187 color242

########################################
# Index View
########################################

color index color187 color235
color index_number color242 color235
color index_author color110 color235
color index_subject color187 color235
color index_date color143 color235
color index_flags color160 color235

color index color131 color235 "~D"
color index color180 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color187 color235
color header color110 color235 "^From:"
color header color110 color235 "^To:"
color header color143 color235 "^Subject:"
color header color143 color235 "^Date:"
color header color109 color235 "^Reply-To:"
color header color109 color235 "^Message-ID:"

########################################
# Body
########################################

color body color187 color235 ".*"
color quoted0 color107 color235
color quoted1 color109 color235
color signature color242 color235
color body color110 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color143

########################################
# Compose
########################################

color compose_header color110 color235
color compose_security_encrypt color160 color235
color compose_security_sign color107 color235
color compose_security_both color109 color235

########################################
# Diff / Patch
########################################

color body color235 color107 "^\\+.*"
color body color235 color131 "^-.*"
color body color235 color143 "^@@.*"

# vim: ft=neomuttrc
