# Dimidium – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Dimidium
#
# Base palette
# bg:  #141414
# fg:  #bab7b6
# grey:#817e7e

########################################
# Global Defaults
########################################

color normal color250 color233
color error color167 color233
color message color32 color233
color indicator color233 color220
color tree color8 color233

########################################
# Status Bar
########################################

color status color250 color8

########################################
# Index View
########################################

color index color250 color233
color index_number color8 color233
color index_author color32 color233
color index_subject color250 color233
color index_date color178 color233
color index_flags color203 color233

color index color167 color233 "~D"
color index color220 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color250 color233
color header color32 color233 "^From:"
color header color32 color233 "^To:"
color header color178 color233 "^Subject:"
color header color178 color233 "^Date:"
color header color81 color233 "^Reply-To:"
color header color81 color233 "^Message-ID:"

########################################
# Body
########################################

color body color250 color233 ".*"
color quoted0 color78 color233
color quoted1 color81 color233
color signature color8 color233
color body color69 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color178

########################################
# Compose
########################################

color compose_header color32 color233
color compose_security_encrypt color203 color233
color compose_security_sign color78 color233
color compose_security_both color81 color233

########################################
# Diff / Patch
########################################

color body color233 color78 "^\\+.*"
color body color233 color167 "^-.*"
color body color233 color178 "^@@.*"

# vim: ft=neomuttrc
