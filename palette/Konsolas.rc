########################################
# Body
########################################

color body color251 color232 ".*"
color quoted0 color83 color232
color quoted1 color87 color232
color signature color243 color232
color body color63 color232 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color232 color178

########################################
