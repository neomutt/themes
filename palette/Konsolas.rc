########################################
# Global Defaults
########################################

color normal color251 color232
color error color124 color232
color message color19 color232
color indicator color232 color227
color tree color243 color232

########################################
# Status Bar
########################################

color status color251 color243

########################################
# Index View
########################################

color index color251 color232
color index_number color243 color232
color index_author color19 color232
color index_subject color251 color232
color index_date color178 color232
color index_flags color203 color232

color index color124 color232 "~D"
