########################################
# Headers
########################################

color hdrdefault color251 color232
color header color19 color232 "^From:"
color header color19 color232 "^To:"
color header color178 color232 "^Subject:"
color header color178 color232 "^Date:"
color header color87 color232 "^Reply-To:"
