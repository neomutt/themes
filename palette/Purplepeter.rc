# Purplepeter – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Purplepeter
#
# Base palette
# bg:  #2a1a4a
# fg:  #ece7fa
# grey:#504b63

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color255 color236
color error color209 color236
color message color81 color236
color indicator color236 color223
color tree color240 color236

########################################
# Status Bar
########################################

color status color255 color240

########################################
# Index View
########################################

color index color255 color236
color index_number color240 color236
color index_author color81 color236
color index_subject color255 color236
color index_date color223 color236
color index_flags color216 color236

color index color209 color236 "~D"
color index color223 color236 "~T"

########################################
# Headers
########################################

color hdrdefault color255 color236
color header color81 color236 "^From:"
color header color81 color236 "^To:"
color header color223 color236 "^Subject:"
color header color223 color236 "^Date:"
color header color146 color236 "^Reply-To:"
color header color146 color236 "^Message-ID:"

########################################
# Body
########################################

color body color255 color236 ".*"
color quoted0 color144 color236
color quoted1 color146 color236
color signature color240 color236
color body color117 color236 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color236 color223

########################################
# Compose
########################################

color compose_header color81 color236
color compose_security_encrypt color216 color236
color compose_security_sign color144 color236
color compose_security_both color146 color236

########################################
# Diff / Patch
########################################

color body color236 color144 "^\\+.*"
color body color236 color209 "^-.*"
color body color236 color223 "^@@.*"

# vim: ft=neomuttrc
