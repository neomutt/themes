# Material Design Colors – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Material Design Colors
#
# Base palette
# bg:  #1d262a
# fg:  #e7ebed
# grey:#a1b0b8

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color255 color235
color error color203 color235
color message color75 color235
color indicator color235 color221
color tree color145 color235

########################################
# Status Bar
########################################

color status color255 color145

########################################
# Index View
########################################

color index color255 color235
color index_number color145 color235
color index_author color75 color235
color index_subject color255 color235
color index_date color221 color235
color index_flags color209 color235

color index color203 color235 "~D"
color index color221 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color255 color235
color header color75 color235 "^From:"
color header color75 color235 "^To:"
color header color221 color235 "^Subject:"
color header color221 color235 "^Date:"
color header color122 color235 "^Reply-To:"
color header color122 color235 "^Message-ID:"

########################################
# Body
########################################

color body color255 color235 ".*"
color quoted0 color157 color235
color quoted1 color122 color235
color signature color145 color235
color body color81 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color221

########################################
# Compose
########################################

color compose_header color75 color235
color compose_security_encrypt color209 color235
color compose_security_sign color157 color235
color compose_security_both color122 color235

########################################
# Diff / Patch
########################################

color body color235 color157 "^\\+.*"
color body color235 color203 "^-.*"
color body color235 color221 "^@@.*"

# vim: ft=neomuttrc
