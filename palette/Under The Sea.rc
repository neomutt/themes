# Under The Sea – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Under The Sea
#
# Base palette
# bg:  #011116
# fg:  #ffffff
# grey:#384451

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color15 color233
color error color130 color233
color message color66 color233
color indicator color233 color117
color tree color238 color233

########################################
# Status Bar
########################################

color status color15 color238

########################################
# Index View
########################################

color index color15 color233
color index_number color238 color233
color index_author color66 color233
color index_subject color15 color233
color index_date color67 color233
color index_flags color203 color233

color index color130 color233 "~D"
color index color117 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color15 color233
color header color66 color233 "^From:"
color header color66 color233 "^To:"
color header color67 color233 "^Subject:"
color header color67 color233 "^Date:"
color header color112 color233 "^Reply-To:"
color header color112 color233 "^Message-ID:"

########################################
# Body
########################################

color body color15 color233 ".*"
color quoted0 color41 color233
color quoted1 color112 color233
color signature color238 color233
color body color79 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color67

########################################
# Compose
########################################

color compose_header color66 color233
color compose_security_encrypt color203 color233
color compose_security_sign color41 color233
color compose_security_both color112 color233

########################################
# Diff / Patch
########################################

color body color233 color41 "^\\+.*"
color body color233 color130 "^-.*"
color body color233 color67 "^@@.*"

# vim: ft=neomuttrc
