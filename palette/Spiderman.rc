########################################
# Global Defaults
########################################

color normal color254 color234
color error color160 color234
color message color27 color234
color indicator color234 color203
color tree color239 color234

########################################
# Status Bar
########################################

color status color254 color239

########################################
# Index View
########################################

color index color254 color234
color index_number color239 color234
color index_author color27 color234
color index_subject color254 color234
color index_date color167 color234
color index_flags color9 color234

color index color160 color234 "~D"
color index color203 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color254 color234
color header color27 color234 "^From:"
color header color27 color234 "^To:"
color header color167 color234 "^Subject:"
color header color167 color234 "^Date:"
color header color69 color234 "^Reply-To:"
color header color69 color234 "^Message-ID:"

########################################
# Body
########################################

color body color254 color234 ".*"
color quoted0 color203 color234
color quoted1 color69 color234
color signature color239 color234
color body color27 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color167

########################################
# Compose
########################################

color compose_header color27 color234
color compose_security_encrypt color9 color234
color compose_security_sign color203 color234
color compose_security_both color69 color234

########################################
# Diff / Patch
########################################

color body color234 color203 "^\\+.*"
