########################################
# Body
########################################

color body color254 color236 ".*"
color quoted0 color113 color236
color quoted1 color37 color236
color signature color103 color236
color body color104 color236 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color236 color173

########################################
