########################################
# Body
########################################

color body color41 color234 ".*"
color quoted0 color29 color234
color quoted1 color72 color234
color signature color240 color234
color body color68 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color172

########################################
# Compose
########################################

