########################################
# Global Defaults
########################################

color normal color41 color234
color error color124 color234
color message color61 color234
color indicator color234 color178
color tree color240 color234

########################################
# Status Bar
########################################

color status color41 color240

########################################
# Index View
########################################

color index color41 color234
color index_number color240 color234
color index_author color61 color234
color index_subject color41 color234
color index_date color172 color234
color index_flags color166 color234

color index color124 color234 "~D"
