color header color117 color236 "^Message-ID:"

########################################
# Body
########################################

color body color255 color236 ".*"
color quoted0 color65 color236
color quoted1 color117 color236
color signature color240 color236
color body color38 color236 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color236 color215

########################################
# Compose
########################################

color compose_header color38 color236
color compose_security_encrypt color124 color236
