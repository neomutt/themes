########################################
# Global Defaults
########################################

color normal color255 color236
color error color124 color236
color message color38 color236
color indicator color236 color215
color tree color240 color236

########################################
# Status Bar
########################################

color status color255 color240

########################################
# Index View
########################################

color index color255 color236
color index_number color240 color236
color index_author color38 color236
