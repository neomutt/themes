# Hardcore – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Hardcore
#
# Base palette
# bg:  #121212
# fg:  #a0a0a0
# grey:#505354

########################################
# Global Defaults
########################################

color normal color247 color233
color error color197 color233
color message color81 color233
color indicator color233 color186
color tree color239 color233

########################################
# Status Bar
########################################

color status color247 color239

########################################
# Index View
########################################

color index color247 color233
color index_number color239 color233
color index_author color81 color233
color index_subject color247 color233
color index_date color208 color233
color index_flags color205 color233

color index color197 color233 "~D"
color index color186 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color247 color233
color header color81 color233 "^From:"
color header color81 color233 "^To:"
color header color208 color233 "^Subject:"
color header color208 color233 "^Date:"
color header color249 color233 "^Reply-To:"
color header color249 color233 "^Message-ID:"

########################################
# Body
########################################

color body color247 color233 ".*"
color quoted0 color155 color233
color quoted1 color249 color233
color signature color239 color233
color body color81 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color208

########################################
# Compose
########################################

color compose_header color81 color233
color compose_security_encrypt color205 color233
color compose_security_sign color155 color233
color compose_security_both color249 color233

########################################
# Diff / Patch
########################################

color body color233 color155 "^\\+.*"
color body color233 color197 "^-.*"
color body color233 color208 "^@@.*"

# vim: ft=neomuttrc
