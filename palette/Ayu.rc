# Ayu – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Ayu
#
# Base palette
# bg:  #0b0e14
# fg:  #bfbdb6
# grey:#686868

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color250 color233
color error color167 color233
color message color75 color233
color indicator color233 color215
color tree color242 color233

########################################
# Status Bar
########################################

color status color250 color242

########################################
# Index View
########################################

color index color250 color233
color index_number color242 color233
color index_author color75 color233
color index_subject color250 color233
color index_date color215 color233
color index_flags color204 color233

color index color167 color233 "~D"
color index color215 color233 "~T"

########################################
# Headers
########################################

color hdrdefault color250 color233
color header color75 color233 "^From:"
color header color75 color233 "^To:"
color header color215 color233 "^Subject:"
color header color215 color233 "^Date:"
color header color116 color233 "^Reply-To:"
color header color116 color233 "^Message-ID:"

########################################
# Body
########################################

color body color250 color233 ".*"
color quoted0 color149 color233
color quoted1 color116 color233
color signature color242 color233
color body color75 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color215

########################################
# Compose
########################################

color compose_header color75 color233
color compose_security_encrypt color204 color233
color compose_security_sign color149 color233
color compose_security_both color116 color233

########################################
# Diff / Patch
########################################

color body color233 color149 "^\\+.*"
color body color233 color167 "^-.*"
color body color233 color215 "^@@.*"

# vim: ft=neomuttrc
