# Black Metal – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Black Metal
#
# Base palette
# bg:  #000000
# fg:  #c1c1c1
# grey:#404040

########################################
# Global Defaults
########################################

color normal color7 color0
color error color241 color0
color message color102 color0
color indicator color0 color131
color tree color238 color0

########################################
# Status Bar
########################################

color status color7 color238

########################################
# Index View
########################################

color index color7 color0
color index_number color238 color0
color index_author color102 color0
color index_subject color7 color0
color index_date color131 color0
color index_flags color241 color0

color index color241 color0 "~D"
color index color131 color0 "~T"

########################################
# Headers
########################################

color hdrdefault color7 color0
color header color102 color0 "^From:"
color header color102 color0 "^To:"
color header color131 color0 "^Subject:"
color header color131 color0 "^Date:"
color header color248 color0 "^Reply-To:"
color header color248 color0 "^Message-ID:"

########################################
# Body
########################################

color body color7 color0 ".*"
color quoted0 color174 color0
color quoted1 color248 color0
color signature color238 color0
color body color102 color0 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color0 color131

########################################
# Compose
########################################

color compose_header color102 color0
color compose_security_encrypt color241 color0
color compose_security_sign color174 color0
color compose_security_both color248 color0

########################################
# Diff / Patch
########################################

color body color0 color174 "^\\+.*"
color body color0 color241 "^-.*"
color body color0 color131 "^@@.*"

# vim: ft=neomuttrc
