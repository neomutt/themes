########################################

color normal color253 color233
color error color202 color233
color message color237 color233
color indicator color233 color228
color tree color239 color233

########################################
# Status Bar
########################################

color status color253 color239

########################################
# Index View
########################################

color index color253 color233
color index_number color239 color233
color index_author color237 color233
color index_subject color253 color233
color index_date color221 color233
color index_flags color209 color233

color index color202 color233 "~D"
