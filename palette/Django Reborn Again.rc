########################################
# Body
########################################

color body color253 color233 ".*"
color quoted0 color77 color233
color quoted1 color194 color233
color signature color239 color233
color body color65 color233 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color233 color221

########################################
