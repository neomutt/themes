########################################
# Headers
########################################

color hdrdefault color255 color235
color header color141 color235 "^From:"
color header color141 color235 "^To:"
color header color222 color235 "^Subject:"
color header color222 color235 "^Date:"
color header color159 color235 "^Reply-To:"
color header color159 color235 "^Message-ID:"

########################################
# Body
########################################

color body color255 color235 ".*"
color quoted0 color157 color235
color quoted1 color159 color235
color signature color60 color235
color body color141 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color222

########################################
# Compose
########################################

color compose_header color141 color235
color compose_security_encrypt color210 color235
color compose_security_sign color157 color235
