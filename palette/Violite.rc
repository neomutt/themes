########################################
# Global Defaults
########################################

color normal color255 color235
color error color210 color235
color message color141 color235
color indicator color235 color222
color tree color60 color235

########################################
# Status Bar
########################################

color status color255 color60

########################################
# Index View
########################################

color index color255 color235
color index_number color60 color235
color index_author color141 color235
color index_subject color255 color235
color index_date color222 color235
color index_flags color210 color235

color index color210 color235 "~D"
