# Hivacruz – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Hivacruz
#
# Base palette
# bg:  #132638
# fg:  #ede4e4
# grey:#6b7394

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color254 color235
color error color166 color235
color message color68 color235
color indicator color235 color60
color tree color60 color235

########################################
# Status Bar
########################################

color status color254 color60

########################################
# Index View
########################################

color index color254 color235
color index_number color60 color235
color index_author color68 color235
color index_subject color254 color235
color index_date color137 color235
color index_flags color166 color235

color index color166 color235 "~D"
color index color60 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color254 color235
color header color68 color235 "^From:"
color header color68 color235 "^To:"
color header color137 color235 "^Subject:"
color header color137 color235 "^Date:"
color header color132 color235 "^Reply-To:"
color header color132 color235 "^Message-ID:"

########################################
# Body
########################################

color body color254 color235 ".*"
color quoted0 color71 color235
color quoted1 color132 color235
color signature color60 color235
color body color103 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color137

########################################
# Compose
########################################

color compose_header color68 color235
color compose_security_encrypt color166 color235
color compose_security_sign color71 color235
color compose_security_both color132 color235

########################################
# Diff / Patch
########################################

color body color235 color71 "^\\+.*"
color body color235 color166 "^-.*"
color body color235 color137 "^@@.*"

# vim: ft=neomuttrc
