# Japanesque – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Japanesque
#
# Base palette
# bg:  #1e1e1e
# fg:  #f7f6ec
# grey:#595b59

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color255 color234
color error color167 color234
color message color68 color234
color indicator color234 color94
color tree color240 color234

########################################
# Status Bar
########################################

color status color255 color240

########################################
# Index View
########################################

color index color255 color234
color index_number color240 color234
color index_author color68 color234
color index_subject color255 color234
color index_date color178 color234
color index_flags color175 color234

color index color167 color234 "~D"
color index color94 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color255 color234
color header color68 color234 "^From:"
color header color68 color234 "^To:"
color header color178 color234 "^Subject:"
color header color178 color234 "^Date:"
color header color110 color234 "^Reply-To:"
color header color110 color234 "^Message-ID:"

########################################
# Body
########################################

color body color255 color234 ".*"
color quoted0 color3 color234
color quoted1 color110 color234
color signature color240 color234
color body color24 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color178

########################################
# Compose
########################################

color compose_header color68 color234
color compose_security_encrypt color175 color234
color compose_security_sign color3 color234
color compose_security_both color110 color234

########################################
# Diff / Patch
########################################

color body color234 color3 "^\\+.*"
color body color234 color167 "^-.*"
color body color234 color178 "^@@.*"

# vim: ft=neomuttrc
