# Cobalt Next Minimal – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Cobalt Next Minimal
#
# Base palette
# bg:  #0b1c24
# fg:  #d7deea
# grey:#62747f

########################################
# Global Defaults
########################################

color normal color254 color234
color error color204 color234
color message color74 color234
color indicator color234 color222
color tree color66 color234

########################################
# Status Bar
########################################

color status color254 color66

########################################
# Index View
########################################

color index color254 color234
color index_number color66 color234
color index_author color74 color234
color index_subject color254 color234
color index_date color221 color234
color index_flags color174 color234

color index color204 color234 "~D"
color index color222 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color254 color234
color header color74 color234 "^From:"
color header color74 color234 "^To:"
color header color221 color234 "^Subject:"
color header color221 color234 "^Date:"
color header color116 color234 "^Reply-To:"
color header color116 color234 "^Message-ID:"

########################################
# Body
########################################

color body color254 color234 ".*"
color quoted0 color151 color234
color quoted1 color116 color234
color signature color66 color234
color body color110 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color221

########################################
# Compose
########################################

color compose_header color74 color234
color compose_security_encrypt color174 color234
color compose_security_sign color151 color234
color compose_security_both color116 color234

########################################
# Diff / Patch
########################################

color body color234 color151 "^\\+.*"
color body color234 color204 "^-.*"
color body color234 color221 "^@@.*"

# vim: ft=neomuttrc
