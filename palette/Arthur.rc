########################################
# Global Defaults
########################################

color normal color254 color234
color error color167 color234
color message color69 color234
color indicator color234 color215
color tree color239 color234

########################################
# Status Bar
########################################

color status color254 color239

########################################
# Index View
########################################

color index color254 color234
color index_number color239 color234
color index_author color69 color234
color index_subject color254 color234
color index_date color179 color234
color index_flags color167 color234

color index color167 color234 "~D"
color index color215 color234 "~T"

########################################
# Headers
########################################

color hdrdefault color254 color234
color header color69 color234 "^From:"
color header color69 color234 "^To:"
color header color179 color234 "^Subject:"
color header color179 color234 "^Date:"
color header color152 color234 "^Reply-To:"
color header color152 color234 "^Message-ID:"

########################################
# Body
########################################

color body color254 color234 ".*"
color quoted0 color106 color234
color quoted1 color152 color234
color signature color239 color234
color body color116 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color179

########################################
# Compose
########################################

color compose_header color69 color234
color compose_security_encrypt color167 color234
color compose_security_sign color106 color234
