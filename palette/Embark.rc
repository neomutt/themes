########################################
# Headers
########################################

color hdrdefault color15 color235
color header color81 color235 "^From:"
color header color81 color235 "^To:"
color header color223 color235 "^Subject:"
color header color223 color235 "^Date:"
color header color87 color235 "^Reply-To:"
color header color87 color235 "^Message-ID:"

########################################
# Body
########################################

color body color15 color235 ".*"
color quoted0 color42 color235
color quoted1 color87 color235
color signature color59 color235
color body color38 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color223

########################################
# Compose
########################################

color compose_header color81 color235
color compose_security_encrypt color197 color235
color compose_security_sign color42 color235
