########################################
# Global Defaults
########################################

color normal color15 color235
color error color204 color235
color message color81 color235
color indicator color235 color216
color tree color59 color235

########################################
# Status Bar
########################################

color status color15 color59

########################################
# Index View
########################################

color index color15 color235
color index_number color59 color235
color index_author color81 color235
color index_subject color15 color235
color index_date color223 color235
color index_flags color197 color235

color index color204 color235 "~D"
