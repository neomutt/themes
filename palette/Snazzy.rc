# Snazzy – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Snazzy
#
# Base palette
# bg:  #1e1f29
# fg:  #ebece6
# grey:#555555

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color255 color235
color error color203 color235
color message color75 color235
color indicator color235 color228
color tree color240 color235

########################################
# Status Bar
########################################

color status color255 color240

########################################
# Index View
########################################

color index color255 color235
color index_number color240 color235
color index_author color75 color235
color index_subject color255 color235
color index_date color228 color235
color index_flags color203 color235

color index color203 color235 "~D"
color index color228 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color255 color235
color header color75 color235 "^From:"
color header color75 color235 "^To:"
color header color228 color235 "^Subject:"
color header color228 color235 "^Date:"
color header color117 color235 "^Reply-To:"
color header color117 color235 "^Message-ID:"

########################################
# Body
########################################

color body color255 color235 ".*"
color quoted0 color84 color235
color quoted1 color117 color235
color signature color240 color235
color body color75 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color228

########################################
# Compose
########################################

color compose_header color75 color235
color compose_security_encrypt color203 color235
color compose_security_sign color84 color235
color compose_security_both color117 color235

########################################
# Diff / Patch
########################################

color body color235 color84 "^\\+.*"
color body color235 color203 "^-.*"
color body color235 color228 "^@@.*"

# vim: ft=neomuttrc
