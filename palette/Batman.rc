########################################
# Global Defaults
########################################

color normal color242 color234
color error color185 color234
color message color243 color234
color indicator color234 color227
color tree color239 color234

########################################
# Status Bar
########################################

color status color242 color239

########################################
# Index View
########################################

color index color242 color234
color index_number color239 color234
color index_author color243 color234
color index_subject color242 color234
color index_date color11 color234
color index_flags color228 color234

color index color185 color234 "~D"
