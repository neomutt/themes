########################################
# Body
########################################

color body color242 color234 ".*"
color quoted0 color228 color234
color quoted1 color248 color234
color signature color239 color234
color body color246 color234 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color234 color11

########################################
# Compose
########################################

