########################################
# Headers
########################################

color hdrdefault color242 color234
color header color243 color234 "^From:"
color header color243 color234 "^To:"
color header color11 color234 "^Subject:"
color header color11 color234 "^Date:"
color header color248 color234 "^Reply-To:"
