# Gruvbox Dark – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Gruvbox Dark
#
# Base palette
# bg:  #282828
# fg:  #ebdbb2
# grey:#928374

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal color187 color235
color error color160 color235
color message color66 color235
color indicator color235 color214
color tree color8 color235

########################################
# Status Bar
########################################

color status color187 color8

########################################
# Index View
########################################

color index color187 color235
color index_number color8 color235
color index_author color66 color235
color index_subject color187 color235
color index_date color172 color235
color index_flags color203 color235

color index color160 color235 "~D"
color index color214 color235 "~T"

########################################
# Headers
########################################

color hdrdefault color187 color235
color header color66 color235 "^From:"
color header color66 color235 "^To:"
color header color172 color235 "^Subject:"
color header color172 color235 "^Date:"
color header color108 color235 "^Reply-To:"
color header color108 color235 "^Message-ID:"

########################################
# Body
########################################

color body color187 color235 ".*"
color quoted0 color142 color235
color quoted1 color108 color235
color signature color8 color235
color body color108 color235 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search color235 color172

########################################
# Compose
########################################

color compose_header color66 color235
color compose_security_encrypt color203 color235
color compose_security_sign color142 color235
color compose_security_both color108 color235

########################################
# Diff / Patch
########################################

color body color235 color142 "^\\+.*"
color body color235 color160 "^-.*"
color body color235 color172 "^@@.*"

# vim: ft=neomuttrc
