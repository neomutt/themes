# Atom One Light – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Atom One Light
#
# Base palette
# bg:  #f9f9f9
# fg:  #2a2c33
# grey:#000000

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #2a2c33 #f9f9f9
color error         #de3e35 #f9f9f9
color message       #2f5af3 #f9f9f9
color indicator     #f9f9f9 #d2b67c
color tree          #000000 #f9f9f9

########################################
# Status Bar
########################################

color status        #2a2c33 #000000

########################################
# Index View
########################################

color index         #2a2c33 #f9f9f9
color index_number  #000000 #f9f9f9
color index_author  #2f5af3 #f9f9f9
color index_subject #2a2c33 #f9f9f9
color index_date    #d2b67c #f9f9f9
color index_flags   #de3e35 #f9f9f9

color index #de3e35 #f9f9f9 "~D"
color index #d2b67c #f9f9f9 "~T"

########################################
# Headers
########################################

color hdrdefault    #2a2c33 #f9f9f9
color header #2f5af3 #f9f9f9 "^From:"
color header #2f5af3 #f9f9f9 "^To:"
color header #d2b67c #f9f9f9 "^Subject:"
color header #d2b67c #f9f9f9 "^Date:"
color header #3f953a #f9f9f9 "^Reply-To:"
color header #3f953a #f9f9f9 "^Message-ID:"

########################################
# Body
########################################

color body          #2a2c33 #f9f9f9 ".*"
color quoted0       #3f953a #f9f9f9
color quoted1       #3f953a #f9f9f9
color signature     #000000 #f9f9f9
color body #2f5af3 #f9f9f9 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #f9f9f9 #d2b67c

########################################
# Compose
########################################

color compose_header #2f5af3 #f9f9f9
color compose_security_encrypt #de3e35 #f9f9f9
color compose_security_sign #3f953a #f9f9f9
color compose_security_both #3f953a #f9f9f9

########################################
# Diff / Patch
########################################

color body #f9f9f9 #3f953a "^\\+.*"
color body #f9f9f9 #de3e35 "^-.*"
color body #f9f9f9 #d2b67c "^@@.*"

# vim: ft=neomuttrc
