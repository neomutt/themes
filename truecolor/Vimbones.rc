# Vimbones – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Vimbones
#
# Base palette
# bg:  #f0f0ca
# fg:  #353535
# grey:#acac89

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #353535 #f0f0ca
color error         #a8334c #f0f0ca
color message       #286486 #f0f0ca
color indicator     #f0f0ca #803d1c
color tree          #acac89 #f0f0ca

########################################
# Status Bar
########################################

color status        #353535 #acac89

########################################
# Index View
########################################

color index         #353535 #f0f0ca
color index_number  #acac89 #f0f0ca
color index_author  #286486 #f0f0ca
color index_subject #353535 #f0f0ca
color index_date    #944927 #f0f0ca
color index_flags   #94253e #f0f0ca

color index #a8334c #f0f0ca "~D"
color index #803d1c #f0f0ca "~T"

########################################
# Headers
########################################

color hdrdefault    #353535 #f0f0ca
color header #286486 #f0f0ca "^From:"
color header #286486 #f0f0ca "^To:"
color header #944927 #f0f0ca "^Subject:"
color header #944927 #f0f0ca "^Date:"
color header #2b747c #f0f0ca "^Reply-To:"
color header #2b747c #f0f0ca "^Message-ID:"

########################################
# Body
########################################

color body          #353535 #f0f0ca ".*"
color quoted0       #3f5a22 #f0f0ca
color quoted1       #2b747c #f0f0ca
color signature     #acac89 #f0f0ca
color body #1d5573 #f0f0ca "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #f0f0ca #944927

########################################
# Compose
########################################

color compose_header #286486 #f0f0ca
color compose_security_encrypt #94253e #f0f0ca
color compose_security_sign #3f5a22 #f0f0ca
color compose_security_both #2b747c #f0f0ca

########################################
# Diff / Patch
########################################

color body #f0f0ca #3f5a22 "^\\+.*"
color body #f0f0ca #a8334c "^-.*"
color body #f0f0ca #944927 "^@@.*"

# vim: ft=neomuttrc
