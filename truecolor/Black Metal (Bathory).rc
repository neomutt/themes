# Black Metal (Bathory) – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Black Metal (Bathory)
#
# Base palette
# bg:  #000000
# fg:  #c1c1c1
# grey:#404040

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #c1c1c1 #000000
color error         #5f8787 #000000
color message       #888888 #000000
color indicator     #000000 #e78a53
color tree          #404040 #000000

########################################
# Status Bar
########################################

color status        #c1c1c1 #404040

########################################
# Index View
########################################

color index         #c1c1c1 #000000
color index_number  #404040 #000000
color index_author  #888888 #000000
color index_subject #c1c1c1 #000000
color index_date    #e78a53 #000000
color index_flags   #5f8787 #000000

color index #5f8787 #000000 "~D"
color index #e78a53 #000000 "~T"

########################################
# Headers
########################################

color hdrdefault    #c1c1c1 #000000
color header #888888 #000000 "^From:"
color header #888888 #000000 "^To:"
color header #e78a53 #000000 "^Subject:"
color header #e78a53 #000000 "^Date:"
color header #aaaaaa #000000 "^Reply-To:"
color header #aaaaaa #000000 "^Message-ID:"

########################################
# Body
########################################

color body          #c1c1c1 #000000 ".*"
color quoted0       #fbcb97 #000000
color quoted1       #aaaaaa #000000
color signature     #404040 #000000
color body #888888 #000000 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #000000 #e78a53

########################################
# Compose
########################################

color compose_header #888888 #000000
color compose_security_encrypt #5f8787 #000000
color compose_security_sign #fbcb97 #000000
color compose_security_both #aaaaaa #000000

########################################
# Diff / Patch
########################################

color body #000000 #fbcb97 "^\\+.*"
color body #000000 #5f8787 "^-.*"
color body #000000 #e78a53 "^@@.*"

# vim: ft=neomuttrc
