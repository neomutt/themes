# Modus Vivendi – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Modus Vivendi
#
# Base palette
# bg:  #000000
# fg:  #ffffff
# grey:#595959

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #ffffff #000000
color error         #ff5f59 #000000
color message       #2fafff #000000
color indicator     #000000 #fec43f
color tree          #595959 #000000

########################################
# Status Bar
########################################

color status        #ffffff #595959

########################################
# Index View
########################################

color index         #ffffff #000000
color index_number  #595959 #000000
color index_author  #2fafff #000000
color index_subject #ffffff #000000
color index_date    #d0bc00 #000000
color index_flags   #ff7f9f #000000

color index #ff5f59 #000000 "~D"
color index #fec43f #000000 "~T"

########################################
# Headers
########################################

color hdrdefault    #ffffff #000000
color header #2fafff #000000 "^From:"
color header #2fafff #000000 "^To:"
color header #d0bc00 #000000 "^Subject:"
color header #d0bc00 #000000 "^Date:"
color header #6ae4b9 #000000 "^Reply-To:"
color header #6ae4b9 #000000 "^Message-ID:"

########################################
# Body
########################################

color body          #ffffff #000000 ".*"
color quoted0       #00c06f #000000
color quoted1       #6ae4b9 #000000
color signature     #595959 #000000
color body #79a8ff #000000 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #000000 #d0bc00

########################################
# Compose
########################################

color compose_header #2fafff #000000
color compose_security_encrypt #ff7f9f #000000
color compose_security_sign #00c06f #000000
color compose_security_both #6ae4b9 #000000

########################################
# Diff / Patch
########################################

color body #000000 #00c06f "^\\+.*"
color body #000000 #ff5f59 "^-.*"
color body #000000 #d0bc00 "^@@.*"

# vim: ft=neomuttrc
