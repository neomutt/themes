# Wez – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Wez
#
# Base palette
# bg:  #000000
# fg:  #b3b3b3
# grey:#555555

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #b3b3b3 #000000
color error         #cc5555 #000000
color message       #5555cc #000000
color indicator     #000000 #ffff55
color tree          #555555 #000000

########################################
# Status Bar
########################################

color status        #b3b3b3 #555555

########################################
# Index View
########################################

color index         #b3b3b3 #000000
color index_number  #555555 #000000
color index_author  #5555cc #000000
color index_subject #b3b3b3 #000000
color index_date    #cdcd55 #000000
color index_flags   #ff5555 #000000

color index #cc5555 #000000 "~D"
color index #ffff55 #000000 "~T"

########################################
# Headers
########################################

color hdrdefault    #b3b3b3 #000000
color header #5555cc #000000 "^From:"
color header #5555cc #000000 "^To:"
color header #cdcd55 #000000 "^Subject:"
color header #cdcd55 #000000 "^Date:"
color header #55ffff #000000 "^Reply-To:"
color header #55ffff #000000 "^Message-ID:"

########################################
# Body
########################################

color body          #b3b3b3 #000000 ".*"
color quoted0       #55ff55 #000000
color quoted1       #55ffff #000000
color signature     #555555 #000000
color body #5555ff #000000 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #000000 #cdcd55

########################################
# Compose
########################################

color compose_header #5555cc #000000
color compose_security_encrypt #ff5555 #000000
color compose_security_sign #55ff55 #000000
color compose_security_both #55ffff #000000

########################################
# Diff / Patch
########################################

color body #000000 #55ff55 "^\\+.*"
color body #000000 #cc5555 "^-.*"
color body #000000 #cdcd55 "^@@.*"

# vim: ft=neomuttrc
