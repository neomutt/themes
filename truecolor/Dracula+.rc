# Dracula+ – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Dracula+
#
# Base palette
# bg:  #212121
# fg:  #f8f8f2
# grey:#545454

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #f8f8f2 #212121
color error         #ff5555 #212121
color message       #82aaff #212121
color indicator     #212121 #ffcb6b
color tree          #545454 #212121

########################################
# Status Bar
########################################

color status        #f8f8f2 #545454

########################################
# Index View
########################################

color index         #f8f8f2 #212121
color index_number  #545454 #212121
color index_author  #82aaff #212121
color index_subject #f8f8f2 #212121
color index_date    #ffcb6b #212121
color index_flags   #ff6e6e #212121

color index #ff5555 #212121 "~D"
color index #ffcb6b #212121 "~T"

########################################
# Headers
########################################

color hdrdefault    #f8f8f2 #212121
color header #82aaff #212121 "^From:"
color header #82aaff #212121 "^To:"
color header #ffcb6b #212121 "^Subject:"
color header #ffcb6b #212121 "^Date:"
color header #a4ffff #212121 "^Reply-To:"
color header #a4ffff #212121 "^Message-ID:"

########################################
# Body
########################################

color body          #f8f8f2 #212121 ".*"
color quoted0       #69ff94 #212121
color quoted1       #a4ffff #212121
color signature     #545454 #212121
color body #d6acff #212121 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #212121 #ffcb6b

########################################
# Compose
########################################

color compose_header #82aaff #212121
color compose_security_encrypt #ff6e6e #212121
color compose_security_sign #69ff94 #212121
color compose_security_both #a4ffff #212121

########################################
# Diff / Patch
########################################

color body #212121 #69ff94 "^\\+.*"
color body #212121 #ff5555 "^-.*"
color body #212121 #ffcb6b "^@@.*"

# vim: ft=neomuttrc
