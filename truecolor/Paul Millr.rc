# Paul Millr – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Paul Millr
#
# Base palette
# bg:  #000000
# fg:  #f2f2f2
# grey:#666666

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #f2f2f2 #000000
color error         #ff0000 #000000
color message       #396bd7 #000000
color indicator     #000000 #f3d64e
color tree          #666666 #000000

########################################
# Status Bar
########################################

color status        #f2f2f2 #666666

########################################
# Index View
########################################

color index         #f2f2f2 #000000
color index_number  #666666 #000000
color index_author  #396bd7 #000000
color index_subject #f2f2f2 #000000
color index_date    #e7bf00 #000000
color index_flags   #ff0080 #000000

color index #ff0000 #000000 "~D"
color index #f3d64e #000000 "~T"

########################################
# Headers
########################################

color hdrdefault    #f2f2f2 #000000
color header #396bd7 #000000 "^From:"
color header #396bd7 #000000 "^To:"
color header #e7bf00 #000000 "^Subject:"
color header #e7bf00 #000000 "^Date:"
color header #7adff2 #000000 "^Reply-To:"
color header #7adff2 #000000 "^Message-ID:"

########################################
# Body
########################################

color body          #f2f2f2 #000000 ".*"
color quoted0       #66ff66 #000000
color quoted1       #7adff2 #000000
color signature     #666666 #000000
color body #709aed #000000 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #000000 #e7bf00

########################################
# Compose
########################################

color compose_header #396bd7 #000000
color compose_security_encrypt #ff0080 #000000
color compose_security_sign #66ff66 #000000
color compose_security_both #7adff2 #000000

########################################
# Diff / Patch
########################################

color body #000000 #66ff66 "^\\+.*"
color body #000000 #ff0000 "^-.*"
color body #000000 #e7bf00 "^@@.*"

# vim: ft=neomuttrc
