# Kanso Mist – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Kanso Mist
#
# Base palette
# bg:  #22262d
# fg:  #c5c9c7
# grey:#5c6066

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #c5c9c7 #22262d
color error         #c4746e #22262d
color message       #8ba4b0 #22262d
color indicator     #22262d #e6c384
color tree          #5c6066 #22262d

########################################
# Status Bar
########################################

color status        #c5c9c7 #5c6066

########################################
# Index View
########################################

color index         #c5c9c7 #22262d
color index_number  #5c6066 #22262d
color index_author  #8ba4b0 #22262d
color index_subject #c5c9c7 #22262d
color index_date    #c4b28a #22262d
color index_flags   #e46876 #22262d

color index #c4746e #22262d "~D"
color index #e6c384 #22262d "~T"

########################################
# Headers
########################################

color hdrdefault    #c5c9c7 #22262d
color header #8ba4b0 #22262d "^From:"
color header #8ba4b0 #22262d "^To:"
color header #c4b28a #22262d "^Subject:"
color header #c4b28a #22262d "^Date:"
color header #7aa89f #22262d "^Reply-To:"
color header #7aa89f #22262d "^Message-ID:"

########################################
# Body
########################################

color body          #c5c9c7 #22262d ".*"
color quoted0       #87a987 #22262d
color quoted1       #7aa89f #22262d
color signature     #5c6066 #22262d
color body #7fb4ca #22262d "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #22262d #c4b28a

########################################
# Compose
########################################

color compose_header #8ba4b0 #22262d
color compose_security_encrypt #e46876 #22262d
color compose_security_sign #87a987 #22262d
color compose_security_both #7aa89f #22262d

########################################
# Diff / Patch
########################################

color body #22262d #87a987 "^\\+.*"
color body #22262d #c4746e "^-.*"
color body #22262d #c4b28a "^@@.*"

# vim: ft=neomuttrc
