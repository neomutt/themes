# Cursor Dark – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Cursor Dark
#
# Base palette
# bg:  #141414
# fg:  #ffffff
# grey:#505050

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #ffffff #141414
color error         #bf616a #141414
color message       #81a1c1 #141414
color indicator     #141414 #ebcb8b
color tree          #505050 #141414

########################################
# Status Bar
########################################

color status        #ffffff #505050

########################################
# Index View
########################################

color index         #ffffff #141414
color index_number  #505050 #141414
color index_author  #81a1c1 #141414
color index_subject #ffffff #141414
color index_date    #ebcb8b #141414
color index_flags   #bf616a #141414

color index #bf616a #141414 "~D"
color index #ebcb8b #141414 "~T"

########################################
# Headers
########################################

color hdrdefault    #ffffff #141414
color header #81a1c1 #141414 "^From:"
color header #81a1c1 #141414 "^To:"
color header #ebcb8b #141414 "^Subject:"
color header #ebcb8b #141414 "^Date:"
color header #88c0d0 #141414 "^Reply-To:"
color header #88c0d0 #141414 "^Message-ID:"

########################################
# Body
########################################

color body          #ffffff #141414 ".*"
color quoted0       #a3be8c #141414
color quoted1       #88c0d0 #141414
color signature     #505050 #141414
color body #81a1c1 #141414 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #141414 #ebcb8b

########################################
# Compose
########################################

color compose_header #81a1c1 #141414
color compose_security_encrypt #bf616a #141414
color compose_security_sign #a3be8c #141414
color compose_security_both #88c0d0 #141414

########################################
# Diff / Patch
########################################

color body #141414 #a3be8c "^\\+.*"
color body #141414 #bf616a "^-.*"
color body #141414 #ebcb8b "^@@.*"

# vim: ft=neomuttrc
