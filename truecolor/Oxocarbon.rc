# Oxocarbon – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Oxocarbon
#
# Base palette
# bg:  #161616
# fg:  #f2f4f8
# grey:#585858

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #f2f4f8 #161616
color error         #00dfdb #161616
color message       #00c15a #161616
color indicator     #161616 #ff4297
color tree          #585858 #161616

########################################
# Status Bar
########################################

color status        #f2f4f8 #585858

########################################
# Index View
########################################

color index         #f2f4f8 #161616
color index_number  #585858 #161616
color index_author  #00c15a #161616
color index_subject #f2f4f8 #161616
color index_date    #ff4297 #161616
color index_flags   #00dfdb #161616

color index #00dfdb #161616 "~D"
color index #ff4297 #161616 "~T"

########################################
# Headers
########################################

color hdrdefault    #f2f4f8 #161616
color header #00c15a #161616 "^From:"
color header #00c15a #161616 "^To:"
color header #ff4297 #161616 "^Subject:"
color header #ff4297 #161616 "^Date:"
color header #ff74b8 #161616 "^Reply-To:"
color header #ff74b8 #161616 "^Message-ID:"

########################################
# Body
########################################

color body          #f2f4f8 #161616 ".*"
color quoted0       #00b4ff #161616
color quoted1       #ff74b8 #161616
color signature     #585858 #161616
color body #00c15a #161616 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #161616 #ff4297

########################################
# Compose
########################################

color compose_header #00c15a #161616
color compose_security_encrypt #00dfdb #161616
color compose_security_sign #00b4ff #161616
color compose_security_both #ff74b8 #161616

########################################
# Diff / Patch
########################################

color body #161616 #00b4ff "^\\+.*"
color body #161616 #00dfdb "^-.*"
color body #161616 #ff4297 "^@@.*"

# vim: ft=neomuttrc
