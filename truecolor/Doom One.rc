# Doom One – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Doom One
#
# Base palette
# bg:  #282c34
# fg:  #bbc2cf
# grey:#595959

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #bbc2cf #282c34
color error         #ff6c6b #282c34
color message       #a9a1e1 #282c34
color indicator     #282c34 #ecbe7b
color tree          #595959 #282c34

########################################
# Status Bar
########################################

color status        #bbc2cf #595959

########################################
# Index View
########################################

color index         #bbc2cf #282c34
color index_number  #595959 #282c34
color index_author  #a9a1e1 #282c34
color index_subject #bbc2cf #282c34
color index_date    #ecbe7b #282c34
color index_flags   #ff6655 #282c34

color index #ff6c6b #282c34 "~D"
color index #ecbe7b #282c34 "~T"

########################################
# Headers
########################################

color hdrdefault    #bbc2cf #282c34
color header #a9a1e1 #282c34 "^From:"
color header #a9a1e1 #282c34 "^To:"
color header #ecbe7b #282c34 "^Subject:"
color header #ecbe7b #282c34 "^Date:"
color header #51afef #282c34 "^Reply-To:"
color header #51afef #282c34 "^Message-ID:"

########################################
# Body
########################################

color body          #bbc2cf #282c34 ".*"
color quoted0       #99bb66 #282c34
color quoted1       #51afef #282c34
color signature     #595959 #282c34
color body #a9a1e1 #282c34 "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #282c34 #ecbe7b

########################################
# Compose
########################################

color compose_header #a9a1e1 #282c34
color compose_security_encrypt #ff6655 #282c34
color compose_security_sign #99bb66 #282c34
color compose_security_both #51afef #282c34

########################################
# Diff / Patch
########################################

color body #282c34 #99bb66 "^\\+.*"
color body #282c34 #ff6c6b "^-.*"
color body #282c34 #ecbe7b "^@@.*"

# vim: ft=neomuttrc
