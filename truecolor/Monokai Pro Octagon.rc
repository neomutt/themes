# Monokai Pro Octagon – NeoMutt adaptation
#
# Generated automatically from iTerm2-Color-Schemes
# Source: Monokai Pro Octagon
#
# Base palette
# bg:  #282a3a
# fg:  #eaf2f1
# grey:#696d77

set color_directcolor = yes

########################################
# Global Defaults
########################################

color normal        #eaf2f1 #282a3a
color error         #ff657a #282a3a
color message       #ff9b5e #282a3a
color indicator     #282a3a #ffd76d
color tree          #696d77 #282a3a

########################################
# Status Bar
########################################

color status        #eaf2f1 #696d77

########################################
# Index View
########################################

color index         #eaf2f1 #282a3a
color index_number  #696d77 #282a3a
color index_author  #ff9b5e #282a3a
color index_subject #eaf2f1 #282a3a
color index_date    #ffd76d #282a3a
color index_flags   #ff657a #282a3a

color index #ff657a #282a3a "~D"
color index #ffd76d #282a3a "~T"

########################################
# Headers
########################################

color hdrdefault    #eaf2f1 #282a3a
color header #ff9b5e #282a3a "^From:"
color header #ff9b5e #282a3a "^To:"
color header #ffd76d #282a3a "^Subject:"
color header #ffd76d #282a3a "^Date:"
color header #9cd1bb #282a3a "^Reply-To:"
color header #9cd1bb #282a3a "^Message-ID:"

########################################
# Body
########################################

color body          #eaf2f1 #282a3a ".*"
color quoted0       #bad761 #282a3a
color quoted1       #9cd1bb #282a3a
color signature     #696d77 #282a3a
color body #ff9b5e #282a3a "(https?|ftp)://[^ ]+"

########################################
# Search
########################################

color search #282a3a #ffd76d

########################################
# Compose
########################################

color compose_header #ff9b5e #282a3a
color compose_security_encrypt #ff657a #282a3a
color compose_security_sign #bad761 #282a3a
color compose_security_both #9cd1bb #282a3a

########################################
# Diff / Patch
########################################

color body #282a3a #bad761 "^\\+.*"
color body #282a3a #ff657a "^-.*"
color body #282a3a #ffd76d "^@@.*"

# vim: ft=neomuttrc
